#pragma once
#include "ecs/lib/flecs.h"
#include "tools/my_multi_mesh_c/my_multi_mesh_c.hpp"
#include "tools/quad_tree_manager/quad_tree_manager.hpp"
#include "ecs/tools/id_pool.hpp"
#include "ecs/tools/static_vector.hpp"
#include "types/bullet_type_c.hpp"
#include "types/unit_type_c.hpp"
#include <godot_cpp/variant/vector2.hpp>
#include <godot_cpp/variant/color.hpp>

using namespace godot;


namespace ecs {
    // ==================================================== 基础 ====================================================
    struct Position { Vector2 value; };
    struct MoveToPosition { Vector2 value; };
    struct TargetPosition { Vector2 value; };
    struct LastPosition { Vector2 value; };
    struct Velocity { Vector2 value; };
    

    struct Acceleration {
        float value;
        float multiplier;
    };

    struct HomingPower { float value; };
    struct HomingRange { float value; };
    struct HomingDelay { float value; };


    struct Rotation { float value; };
    struct RotateSpeed { float value; };

    struct Lifetime {
        float lifetime;
        float age;
    };

    struct Health {
        float current;
        float max;

        bool is_alive() const { return current > 0; }
    };
    struct TickHealAmount { float value; };


    struct ColorComp { Color value; };
    // struct ColorSet { std::vector<Color> value; };
    struct Team { int value; };
    struct SizeValue { float value; };
    struct SizeVector { Vector2 value; };
    struct ScaleValue { float value; };
    struct ScaleVector { Vector2 value; };

    // 拖尾
    struct Trail {
        static constexpr float EPS = 0.0001f;
        static constexpr int MAX_POINTS = 64;

        std::array<Vector2, MAX_POINTS> points{};
        int max_len = 2;
        int now_len = 0;
        int next_point = 0;
        float max_width = 0.0f;
        Color front_color = Color(1, 1, 1);
        Color back_color = Color(1, 1, 1);

        bool gradient() const {
            return front_color != back_color;
        }
    };
    struct TrailDrawer { RID canvas_rid; };


    // ==================================================== 子弹 ====================================================
    // 子弹类型配置（创建时设置，只读）
    struct BulletTypeComp {
        bool collide_unit  = true;
        bool collide_block = true;
        bool  hit_once = false;
        float ground_unit_damage_multi = 1.0;
        float air_unit_damage_multi    = 1.0;
        float block_damage_multi       = 1.0;
        float splash_range = 0.0;
        float splash_damage = 0.0;
        float splash_knockback = 0.0;
        float knockback = 0.0;
        float speed = 150.0f;
        float crit_chance = 0.0f;
        float shake = 0.0f;
        int   pierce_cap   = 0;
        Vector2 scale_from = Vector2(1, 1);
        Vector2 scale_to = Vector2(1, 1);

        BulletTypeC* bullet_type = nullptr;
    };
    
    // 子弹运行时伤害数据
    struct BulletDamage {
        float damage = 0.0f;
        float damage_multi = 1.0f;
        float cutting_damage = 0.0f;
        float armor_pierce = 0.0f;
    };

    // 子弹碰撞运行时状态
    struct BulletCollision {
        bool collide = true;
        bool hittable = true;
        int pierce_remaining = 0;
		StaticVector<int64_t, 16> collided;
        // 已碰撞 Object ID 列表（防重复）
    };

    // 子弹出生点（用于距离检测）
    struct BulletOrigin {
        Vector2 value;
    };

    // GDScript 侧 Bullet 对象引用索引
    // struct GDBulletRef {
    //     int bullet_index = -1;
    //     int type_index = -1;
    // };
    

    // 目标标签
    struct Flying {};
    struct Ground {};
    struct IsBlock {};

    // 子弹类型
    struct PointBullet {};
    struct LightingBullet {};

    // ==================================================== 单位 ====================================================
    // 单位类型配置（创建时设置，只读）
    struct UnitTypeComp {
        // bool collide_unit  = true;
        // bool collide_block = true;
        // bool  hit_once = false;
        // float ground_unit_damage_multi = 1.0;
        // float air_unit_damage_multi    = 1.0;
        // float block_damage_multi       = 1.0;
        // float splash_range = 0.0;
        // float splash_damage = 0.0;
        // float splash_knockback = 0.0;
        // float knockback = 0.0;
        // float speed = 150.0f;
        // float crit_chance = 0.0f;
        // float shake = 0.0f;
        // int   pierce_cap   = 0;
        // Vector2 scale_from = Vector2(1, 1);
        // Vector2 scale_to = Vector2(1, 1);

        UnitTypeC* unit_type = nullptr;
    };
    

    struct Enemy {};
    struct NPC {};
    struct Summoned {};
    struct Player {};

    // ==================================================== 单例 ====================================================
    struct QuadTreeComp { QuadTreeManagerC* ptr; };
    struct BulletDrawer { MyMultiMeshC* ptr; };
    struct EffectCircleDrawer { MyMultiMeshC* ptr; };
    struct EffectRectDrawer { MyMultiMeshC* ptr; };
    struct EffectTriangleDrawer { MyMultiMeshC* ptr; };
    struct PointLightDrawer { MyMultiMeshC* ptr; };

    // ==================================================== 粒子 ====================================================
    struct ParticleInfo {
        static inline IDPool<int> particle_ids;

        Vector2 pos_from;
        Vector2 pos_to;
        float pos_ease;
        Color color_from;
        Color color_to;
        float color_ease;
        Vector2 scale_from;
        Vector2 scale_to;
        float scale_ease;
        float rotation;
        float lifetime;



        int id;
    };

    struct TorusParticleInfo {
        float width_from;
        float width_to;
    };

    struct CircleParticle {};
    struct RectParticle {};
    struct TriangleParticle {};
    struct TorusParticle {};
    

    // on_add	void(flecs::entity, T&)	组件首次添加到 entity
    // on_remove	void(flecs::entity, T&)	组件被移除 / entity 销毁
    // on_set	void(flecs::entity, T&)	组件值被设置时（含首次 set）
    // on_replace	void(flecs::entity, T&, T&)	组件值被替换时（旧值, 新值）
    // on_compare	int(const T*, const T*, ...)	排序比较
    // on_equals	bool(const T*, const T*, ...)	相等性比较
    inline void register_components(flecs::world &world) {
        world.component<Position>();
        world.component<MoveToPosition>();
        world.component<Velocity>();
        world.component<Acceleration>();

        world.component<HomingPower>();
        world.component<HomingRange>();
        world.component<HomingDelay>();

        world.component<Rotation>();
        world.component<RotateSpeed>();

        world.component<Lifetime>();

        world.component<Health>();
        world.component<TickHealAmount>();

        world.component<ColorComp>();

        //world.component<ColorSet>();

        world.component<Team>();

        world.component<TargetPosition>();

        world.component<SizeValue>();
        world.component<SizeVector>();
        world.component<ScaleValue>();
        world.component<ScaleVector>();

        world.component<Trail>();


        // 子弹
        world.component<BulletTypeComp>();
        world.component<BulletDamage>();
        world.component<BulletCollision>();
        world.component<BulletOrigin>();

        world.component<PointBullet>();
        world.component<LightingBullet>();

        // world.component<GDBulletRef>();

        world.component<Flying>();
        world.component<Ground>();
        world.component<IsBlock>();

        // 单位
        world.component<UnitTypeComp>();
        
        world.component<Enemy>();
        world.component<NPC>();
        world.component<Summoned>();
        world.component<Player>();

        // 单例
        //world.component<QuadTreeComp>();
        //world.component<BulletDrawer>();
        //world.component<EffectCircleDrawer>();
        //world.component<EffectRectDrawer>();
        //world.component<EffectTriangleDrawer>();
        //world.component<PointLightDrawer>();
        //world.component<TrailDrawer>();

        // 粒子
        world.component<ParticleInfo>()
            .on_set([](flecs::entity, ParticleInfo& p) {
                // UtilityFunctions::print("acq ", p.id);
                p.id = ParticleInfo::particle_ids.acquire();
            })
            .on_remove([](flecs::entity, ParticleInfo& p) {
                // UtilityFunctions::print("rel ", p.id);
                ParticleInfo::particle_ids.release(p.id);
            });
        world.component<TorusParticleInfo>();
        world.component<CircleParticle>();
        world.component<RectParticle>();
        world.component<TriangleParticle>();
        world.component<TorusParticle>();
    };
} // namespace ecs